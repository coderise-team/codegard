# Backend
SECRET_KEY=your-django-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=codegard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/codegard

# Redis
REDIS_PASSWORD=your-redis-password-here

# Judge
JUDGE_SECRET_KEY=your-judge-secret-key-here
JUDGE_URL=http://judge:8001

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional: public domain for R2 bucket (if configured)
R2_CUSTOM_DOMAIN=

# Signed URLs (recommended for private bucket)
R2_QUERYSTRING_AUTH=true
R2_QUERYSTRING_EXPIRE=3600
